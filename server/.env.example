# River Magnets Server � Environment Variables

PORT=3000
NODE_ENV=development
SERVE_STATIC=true

# Auth
JWT_SECRET=change-me-in-production
ADMIN_KEY=river-admin-dev
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# AI
SEEDREAM_API_KEY=

# Stripe (optional � without it orders stay pending/unpaid)
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Local Stripe webhook forwarding:
#   stripe listen --forward-to localhost:3000/api/payments/webhook
# Copy the whsec_... secret to STRIPE_WEBHOOK_SECRET above

# Email (optional � Resend)
RESEND_API_KEY=
EMAIL_FROM=River Magnets <noreply@rivermagnets.com>

# URLs (when SERVE_STATIC=true, use port 3000 for everything)
APP_URL=http://localhost:3000
API_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,https://iriver-hub.github.io

# Production example (Railway + GitHub Pages):
# APP_URL=https://iriver-hub.github.io/P1
# API_URL=https://your-app.up.railway.app
# CORS_ORIGINS=https://iriver-hub.github.io
# SERVE_STATIC=false
